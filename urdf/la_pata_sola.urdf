    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://parcial2/meshes/link_p.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_p" type="revolute">
    <origin xyz="-0.0403 0 0.075" rpy="1.5708 0 -1.5706"/>
    <parent link="link_c"/>
    <child  link="link_p"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-1.57" upper="1.57" effort="0" velocity="0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       LINK_R  (tibia — eslabón 3, rotación sobre Z local)
       joint_r:  traslación (0.3505, -2.9381E-05, -0.00365) + yaw=0.026978 rad
  ═══════════════════════════════════════════════════════════════ -->
  <link name="link_r">
    <inertial>
      <origin xyz="0.0467273676060766 -4.04422570605967E-09 0.0886045200025964" rpy="0 0 0"/>
      <mass value="0.522331316228209"/>
      <inertia ixx="0.000574365008314387" ixy="1.17685178957624E-10"
               ixz="-8.53933466036227E-06"
               iyy="0.00125001245680216"  iyz="-2.66794242487717E-10"
               izz="0.001659392848682"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://parcial2/meshes/link_r.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1"/>
